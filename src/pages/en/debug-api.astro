---
import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer";
import ApiDiagnosticsPanel from "@/components/ApiDiagnosticsPanel";
import { getDictionary } from "@/lib/i18n";

const locale = "en" as const;
const dict = getDictionary(locale);
const basePath = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<MainLayout
  title="DeckRadar API Debug (temporary)"
  description="Temporary DeckRadar page to diagnose Edge Functions responses."
  locale={locale}
  path={currentPath}
  robots="noindex, nofollow"
>
  <Header locale={locale} dict={dict} currentPath={currentPath} basePath={basePath} />
  <ApiDiagnosticsPanel locale={locale} client:load />
  <Footer dict={dict} />
</MainLayout>
