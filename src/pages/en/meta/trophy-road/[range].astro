---
import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer";
import SeoDeckList from "@/components/SeoDeckList.astro";
import { getDictionary } from "@/lib/i18n";
import { loadTrophyRangeDecks } from "@/lib/metaDeckData";
import {
  TROPHY_ROAD_RANGES,
  buildAnalyzePath,
  buildRankedPath,
  buildTrophyRoadPath,
  getRangeFaq,
  getRangeHeading,
  getRangeIntro,
  getRangeMetaDescription,
  getRangeMetaTitle,
  getRangeNeighbors,
  getTrophyRangeFromSlug
} from "@/lib/metaSeo";
import { buildBreadcrumbJsonLd, buildFaqJsonLd } from "@/lib/structuredData";

export function getStaticPaths() {
  return TROPHY_ROAD_RANGES.map((range) => ({ params: { range: range.slug } }));
}

const locale = "en" as const;
const dict = getDictionary(locale);
const basePath = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const slug = Astro.params.range ?? "";
const range = getTrophyRangeFromSlug(slug);

if (!range) {
  throw new Error(`Unknown trophy road range slug: ${slug}`);
}

const title = getRangeMetaTitle(locale, range);
const description = getRangeMetaDescription(locale, range);
const heading = getRangeHeading(locale, range);
const intro = getRangeIntro(locale, range);
const faqEntries = getRangeFaq(locale, range);
const decks = await loadTrophyRangeDecks(range);
const neighbors = getRangeNeighbors(range.slug);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "DeckRadar", item: new URL("/en/", Astro.site).toString() },
  { name: "Meta", item: new URL("/en/meta/", Astro.site).toString() },
  { name: "Trophy Road", item: new URL("/en/meta/trophy-road/", Astro.site).toString() },
  {
    name: `${range.min}-${range.max}`,
    item: new URL(buildTrophyRoadPath(locale, range.slug), Astro.site).toString()
  }
]);

const faqJsonLd = buildFaqJsonLd(faqEntries);
---

<MainLayout title={title} description={description} locale={locale} path={currentPath}>
  <Header locale={locale} dict={dict} currentPath={currentPath} basePath={basePath} />

  <section class="section-wrap mt-8 space-y-5">
    <nav aria-label="Breadcrumb" class="text-xs text-slate-300">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/en/" class="hover:text-white">DeckRadar</a></li>
        <li>/</li>
        <li><a href="/en/meta/" class="hover:text-white">Meta</a></li>
        <li>/</li>
        <li><a href="/en/meta/trophy-road/" class="hover:text-white">Trophy Road</a></li>
        <li>/</li>
        <li class="text-white">{range.min}-{range.max}</li>
      </ol>
    </nav>

    <article class="glass-panel p-5 sm:p-6">
      <h1 class="font-display text-3xl font-bold text-white">{heading}</h1>
      <p class="mt-3 text-sm leading-relaxed text-slate-300">{intro}</p>
    </article>

    <article class="glass-panel p-5">
      <h2 class="font-display text-2xl font-semibold text-white">
        Best decks in this range ({range.min}-{range.max})
      </h2>
      <p class="mt-2 text-sm text-slate-300">
        Based on analyzed games in this trophy bracket. Stats updated automatically every day.
      </p>
    </article>

    <SeoDeckList locale={locale} decks={decks} />

    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
      <a
        href={neighbors.previous ? buildTrophyRoadPath(locale, neighbors.previous.slug) : buildTrophyRoadPath(locale)}
        class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-200 hover:bg-white/10"
      >
        {neighbors.previous
          ? `Previous range: ${neighbors.previous.min}-${neighbors.previous.max}`
          : "Back to Trophy Road hub"}
      </a>
      <a
        href={neighbors.next ? buildTrophyRoadPath(locale, neighbors.next.slug) : buildTrophyRoadPath(locale)}
        class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-200 hover:bg-white/10"
      >
        {neighbors.next
          ? `Next range: ${neighbors.next.min}-${neighbors.next.max}`
          : "View all ranges"}
      </a>
    </div>

    <div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
      <a class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm hover:bg-white/10" href={buildAnalyzePath(locale)}>
        Analyze player
      </a>
      <a class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm hover:bg-white/10" href="/en/pro-tracking/">
        Pro Tracking
      </a>
      <a class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm hover:bg-white/10" href={buildRankedPath(locale)}>
        Ranked meta
      </a>
    </div>

    <article class="glass-panel p-5">
      <h2 class="font-display text-2xl font-semibold text-white">FAQ</h2>
      <div class="mt-4 space-y-3">
        {faqEntries.map((entry) => (
          <div class="rounded-xl border border-white/10 bg-white/5 p-4">
            <h3 class="text-sm font-semibold text-white">{entry.question}</h3>
            <p class="mt-2 text-sm text-slate-300">{entry.answer}</p>
          </div>
        ))}
      </div>
    </article>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <Footer dict={dict} />
</MainLayout>

