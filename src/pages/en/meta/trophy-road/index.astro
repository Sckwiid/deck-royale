---
import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer";
import { getDictionary } from "@/lib/i18n";
import {
  TROPHY_ROAD_RANGES,
  buildAnalyzePath,
  buildRankedPath,
  buildTrophyRoadPath,
  getTrophyRoadHubDescription,
  getTrophyRoadHubTitle
} from "@/lib/metaSeo";
import { buildBreadcrumbJsonLd } from "@/lib/structuredData";

const locale = "en" as const;
const dict = getDictionary(locale);
const basePath = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const title = getTrophyRoadHubTitle(locale);
const description = getTrophyRoadHubDescription(locale);

const format = (value: number) => new Intl.NumberFormat("en-US").format(value);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "DeckRadar", item: new URL("/en/", Astro.site).toString() },
  { name: "Meta", item: new URL("/en/meta/", Astro.site).toString() },
  { name: "Trophy Road", item: new URL("/en/meta/trophy-road/", Astro.site).toString() }
]);
---

<MainLayout title={title} description={description} locale={locale} path={currentPath}>
  <Header locale={locale} dict={dict} currentPath={currentPath} basePath={basePath} />

  <section class="section-wrap mt-8 space-y-5">
    <nav aria-label="Breadcrumb" class="text-xs text-slate-300">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/en/" class="hover:text-white">DeckRadar</a></li>
        <li>/</li>
        <li><a href="/en/meta/" class="hover:text-white">Meta</a></li>
        <li>/</li>
        <li class="text-white">Trophy Road</li>
      </ol>
    </nav>

    <article class="glass-panel p-5 sm:p-6">
      <h1 class="font-display text-3xl font-bold text-white">Clash Royale Trophy Road Decks by Range</h1>
      <p class="mt-3 text-sm leading-relaxed text-slate-300">
        Explore detailed 250-trophy pages with top-performing decks, observed win rates, and analyzed game volume. This structure helps you target the exact ladder environment where your next push happens.
      </p>
    </article>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {TROPHY_ROAD_RANGES.map((range) => (
        <a
          href={buildTrophyRoadPath(locale, range.slug)}
          class="glass-panel rounded-xl p-4 transition hover:border-cyan-300/35"
        >
          <h2 class="font-display text-2xl font-semibold text-white">
            {format(range.min)} - {format(range.max)} trophies
          </h2>
          <p class="mt-2 text-sm text-slate-300">
            View top decks, average win rate, and meta trends for this trophy bracket.
          </p>
        </a>
      ))}
    </div>

    <div class="glass-panel p-5">
      <h2 class="font-display text-2xl font-semibold text-white">Useful links</h2>
      <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3">
        <a class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm hover:bg-white/10" href={buildAnalyzePath(locale)}>
          Analyze my profile
        </a>
        <a class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm hover:bg-white/10" href="/en/pro-tracking/">
          Pro Tracking
        </a>
        <a class="rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm hover:bg-white/10" href={buildRankedPath(locale)}>
          Ranked meta
        </a>
      </div>
    </div>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <Footer dict={dict} />
</MainLayout>

