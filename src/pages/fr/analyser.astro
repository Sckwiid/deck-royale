---
import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer";
import HeroSearch from "@/components/HeroSearch.astro";
import { getDictionary } from "@/lib/i18n";

const locale = "fr" as const;
const dict = getDictionary(locale);
const basePath = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<MainLayout
  title={dict.seo.analyzeTitle}
  description={dict.seo.homeDescription}
  locale={locale}
  path={currentPath}
>
  <Header locale={locale} dict={dict} currentPath={currentPath} basePath={basePath} />
  <HeroSearch locale={locale} dict={dict} basePath={basePath} />

  <section class="section-wrap mt-8">
    <div class="glass-panel p-5">
      <h1 class="font-display text-3xl font-bold text-white">{dict.nav.analyze}</h1>
      <p class="mt-2 text-sm text-slate-300">
        Analyse avancée des performances, decks recommandés et points d’optimisation par range de trophées.
      </p>
    </div>
  </section>

  <Footer dict={dict} />
</MainLayout>
