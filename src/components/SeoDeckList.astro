---
import type { SeoDeckEntry } from "@/lib/metaDeckData";
import type { SeoLocale } from "@/lib/metaSeo";

interface Props {
  locale: SeoLocale;
  decks: SeoDeckEntry[];
}

const { locale, decks } = Astro.props;

const labels =
  locale === "fr"
    ? {
        winrate: "Winrate",
        games: "Basé sur",
        daily: "Stats mises a jour automatiquement chaque jour",
        avgElixir: "Elixir moyen",
        noDataTitle: "Aucune donnee disponible",
        noDataText:
          "Les statistiques detaillees ne sont pas encore disponibles pour cette plage. La page reste indexable et sera enrichie automatiquement."
      }
    : {
        winrate: "Win rate",
        games: "Based on",
        daily: "Stats updated automatically every day",
        avgElixir: "Average elixir",
        noDataTitle: "No data available",
        noDataText:
          "Detailed stats are not available for this range yet. This page remains indexable and will be enriched automatically."
      };
---

{
  decks.length === 0 ? (
    <article class="glass-panel p-5">
      <h3 class="font-display text-xl font-semibold text-white">{labels.noDataTitle}</h3>
      <p class="mt-2 text-sm text-slate-300">{labels.noDataText}</p>
      <p class="mt-4 text-xs uppercase tracking-[0.08em] text-cyan-200/80">{labels.daily}</p>
    </article>
  ) : (
    <div class="grid grid-cols-1 gap-3">
      {decks.map((deck, index) => (
        <article class="glass-panel p-4" aria-label={`Deck ${index + 1}`}>
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-display text-xl font-semibold text-white">{deck.label}</h3>
              <p class="text-xs uppercase tracking-[0.16em] text-cyan-200/80">{deck.mode}</p>
            </div>
            <span class="rounded-full border border-cyan-300/40 bg-cyan-300/10 px-2.5 py-1 text-xs font-semibold text-cyan-100">
              {deck.winrate === null ? "N/A" : `${deck.winrate.toFixed(1)}%`}
            </span>
          </div>

          <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3">
            <div class="rounded-lg border border-white/10 bg-white/5 px-3 py-2">
              <p class="text-[11px] uppercase tracking-[0.08em] text-slate-300">{labels.winrate}</p>
              <p class="mt-1 text-sm font-semibold text-white">
                {deck.winrate === null ? "N/A" : `${deck.winrate.toFixed(1)}%`}
              </p>
            </div>
            <div class="rounded-lg border border-white/10 bg-white/5 px-3 py-2">
              <p class="text-[11px] uppercase tracking-[0.08em] text-slate-300">{labels.games}</p>
              <p class="mt-1 text-sm font-semibold text-white">{deck.games} games</p>
            </div>
            <div class="rounded-lg border border-white/10 bg-white/5 px-3 py-2">
              <p class="text-[11px] uppercase tracking-[0.08em] text-slate-300">{labels.avgElixir}</p>
              <p class="mt-1 text-sm font-semibold text-white">
                {deck.avgElixir === null ? "N/A" : deck.avgElixir.toFixed(1)}
              </p>
            </div>
          </div>

          <p class="mt-3 text-xs text-slate-300">
            {labels.games} {deck.games} games.
          </p>
          <p class="mt-1 text-xs uppercase tracking-[0.08em] text-cyan-200/80">{labels.daily}</p>
        </article>
      ))}
    </div>
  )
}

