---
import type { Dictionary } from "@/data/i18n";
import type { Locale } from "@/types";

interface HeroSearchProps {
  locale: Locale;
  dict: Dictionary;
  basePath: string;
}

const { locale, dict, basePath } = Astro.props as HeroSearchProps;
const normalizedBase =
  !basePath || basePath === "/" ? "" : basePath.endsWith("/") ? basePath.slice(0, -1) : basePath;
---

<section class="section-wrap mt-8 sm:mt-12">
  <div class="glass-panel scan-layer relative overflow-hidden px-5 py-10 sm:px-8 sm:py-12 lg:px-12 lg:py-14">
    <div class="absolute -left-12 top-8 h-40 w-40 rounded-full bg-cyan-300/20 blur-3xl" />
    <div class="absolute -right-12 bottom-2 h-44 w-44 rounded-full bg-violet-400/15 blur-3xl" />

    <div class="relative z-10 max-w-3xl space-y-6">
      <span class="inline-flex items-center rounded-full border border-cyan-300/35 bg-cyan-300/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.25em] text-cyan-200">
        {dict.hero.badge}
      </span>
      <h1 class="font-display text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
        <span class="text-gradient">{dict.hero.title}</span>
      </h1>
      <p class="max-w-2xl text-sm text-slate-300 sm:text-base">{dict.hero.subtitle}</p>

      <form
        class="flex flex-col gap-3 sm:flex-row sm:items-center"
        data-hero-search
        method="get"
        action={`${normalizedBase}/${locale}/player/`}
      >
        <label for="player-tag" class="sr-only">
          {locale === "fr" ? "Tag joueur Clash Royale" : "Clash Royale player tag"}
        </label>
        <input
          id="player-tag"
          name="tag"
          placeholder={dict.hero.placeholder}
          class="h-12 min-w-[44px] w-full rounded-xl border border-white/15 bg-black/35 px-4 text-sm text-white outline-none transition placeholder:text-slate-400 focus:border-cyan-300/50 focus:ring-2 focus:ring-cyan-300/20 sm:flex-1"
          autocomplete="off"
          spellcheck="false"
          inputmode="text"
          required
          aria-describedby="hero-search-help"
        />
        <button
          type="submit"
          class="h-12 min-w-[44px] rounded-xl bg-gradient-to-r from-cyan-400 via-cyan-300 to-violet-400 px-5 font-semibold text-slate-950 transition hover:scale-[1.01] hover:shadow-glow"
        >
          {dict.hero.button}
        </button>
      </form>
      <p id="hero-search-help" class="text-xs text-slate-400">
        {locale === "fr"
          ? "Format accepté: #2PP, #L8Q9R2."
          : "Accepted format: #2PP, #L8Q9R2."}
      </p>
    </div>
  </div>
</section>

<script is:inline define:vars={{ locale, normalizedBase }}>
  (() => {
    const form = document.querySelector("[data-hero-search]");
    if (!(form instanceof HTMLFormElement)) {
      return;
    }

    const input = form.querySelector("input[name='tag']");
    if (!(input instanceof HTMLInputElement)) {
      return;
    }

    const tagRegex = /[^0289PYLQGRJCUV]/g;
    const invalidMessage =
      locale === "fr"
        ? "Entrez un tag joueur valide (ex: #2PP)."
        : "Enter a valid player tag (example: #2PP).";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      input.setCustomValidity("");

      const clean = input.value.trim().toUpperCase().replace(/^#+/, "").replace(tagRegex, "");
      if (clean.length < 3 || clean.length > 15) {
        input.setCustomValidity(invalidMessage);
        input.reportValidity();
        return;
      }

      const encodedTag = encodeURIComponent(`#${clean}`);
      const destination = `${normalizedBase}/${locale}/player/?tag=${encodedTag}`;

      try {
        localStorage.setItem("deckradar.lastTag", clean);
      } catch {
        // localStorage blocked.
      }

      window.location.assign(destination);
    });
  })();
</script>
