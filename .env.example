# Frontend (public)
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
PUBLIC_FUNCTIONS_BASE_URL=https://YOUR_PROJECT.functions.supabase.co

# SEO / deployment
PUBLIC_SITE_URL=https://YOUR_GITHUB_USERNAME.github.io
PUBLIC_BASE_PATH=/

# GitHub Actions secrets (repository secrets/variables)
# Used by workflows, not by local frontend runtime:
CRON_SCAN_URL=https://YOUR_PROJECT.functions.supabase.co/cron-scan
SYNC_CARDS_URL=https://YOUR_PROJECT.functions.supabase.co/sync-cards

# Backend only (Edge Functions runtime)
# Configure these in Supabase project secrets, never in frontend .env
CLASH_API_BASE_URL=https://proxy.royaleapi.dev/v1
CLASH_ROYALE_API_TOKEN=YOUR_CLASH_ROYALE_API_TOKEN
PROJECT_URL=https://YOUR_PROJECT.supabase.co
SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
CRON_SECRET=YOUR_CRON_SECRET
ALLOWED_ORIGINS=https://YOUR_GITHUB_USERNAME.github.io
# Optional backward-compatible alias supported by current code:
CORS_ALLOWED_ORIGINS=https://YOUR_GITHUB_USERNAME.github.io
